<reactive:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:reactive="http://reactiveui.net"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Transcriber.Client.Desktop.ViewModels.SettingDetails"
             mc:Ignorable="d"
             x:Class="Transcriber.Client.Desktop.Views.SettingDetails.TextDisplaySettingDetailsView"
             x:TypeArguments="vm:TextDisplaySettingDetailsViewModel"
             x:DataType="vm:TextDisplaySettingDetailsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="4">
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Позиция окна" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#9C27B0"
                               Margin="0,0,0,10"/>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Отступ слева" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.WindowLeft}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="0" 
                                Maximum="{Binding Settings.MaxLeft}" 
                                Value="{Binding Settings.WindowLeft}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Отступ сверху" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.WindowTop}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="0" 
                                Maximum="{Binding Settings.MaxTop}" 
                                Value="{Binding Settings.WindowTop}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Размер окна" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#9C27B0"
                               Margin="0,0,0,10"/>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Ширина" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.WindowWidth}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="200" 
                                Maximum="1000" 
                                Value="{Binding Settings.WindowWidth}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Высота" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.WindowHeight}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="100" 
                                Maximum="800" 
                                Value="{Binding Settings.WindowHeight}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Прозрачность" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#9C27B0"
                               Margin="0,0,0,10"/>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Окно" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.WindowOpacity, StringFormat='{}{0:P0}'}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="0" 
                                Maximum="1" 
                                Value="{Binding Settings.WindowOpacity}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Текст" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.TextOpacity, StringFormat='{}{0:P0}'}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="0.1" 
                                Maximum="1" 
                                Value="{Binding Settings.TextOpacity}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Текст" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#9C27B0"
                               Margin="0,0,0,10"/>
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                            <TextBlock Text="Размер" 
                                       VerticalAlignment="Center"
                                       Foreground="#212121"/>
                            <TextBlock Text="{Binding Settings.FontSize, StringFormat='{}{0} pt'}" 
                                       Grid.Column="1"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"
                                       MinWidth="40"
                                       TextAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="8" 
                                Maximum="40" 
                                Value="{Binding Settings.FontSize}"
                                Foreground="#2196F3"
                                Background="#E0E0E0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Пример текста" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#9C27B0"
                               Margin="0,0,0,10"/>
                    <StackPanel Spacing="4">
                        <TextBox Text="{Binding PreviewText}" 
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="80"
                                 BorderThickness="1"
                                 BorderBrush="#9E9E9E"
                                 CornerRadius="3"/>
                            
                        <Button Command="{Binding GenerateRandomPreviewTextCommand}"
                                Background="#2196F3"
                                Foreground="#FFFFFF"
                                BorderThickness="0"
                                CornerRadius="3"
                                Height="36"
                                Padding="15,0"
                                HorizontalAlignment="Stretch">
                            <StackPanel
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                                <TextBlock>
                                    Случайный текст
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Button Command="{Binding NavigateBackCommand}"
                    Background="#9C27B0"
                    Foreground="#FFFFFF"
                    BorderThickness="0"
                    CornerRadius="3"
                    Height="36"
                    Margin="0,4,0,0"
                    Cursor="Hand"
                    HorizontalAlignment="Right">
                <StackPanel
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">
                    <TextBlock>
                        Назад
                    </TextBlock>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</reactive:ReactiveUserControl>