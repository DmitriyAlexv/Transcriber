<reactive:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:reactive="http://reactiveui.net"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Transcriber.Client.Desktop.ViewModels.Controls.SettingsView"
             xmlns:settingsView="clr-namespace:Transcriber.Client.Desktop.Views.Controls.SettingsView"
             mc:Ignorable="d"
             x:Class="Transcriber.Client.Desktop.Views.Controls.SettingsView.SettingsNavigationView"
             x:TypeArguments="vm:SettingsNavigationViewModel"
             x:DataType="vm:SettingsNavigationViewModel">
    
    <StackPanel Spacing="12">
        <settingsView:SettingDetailsNavigationItem 
            DataContext="{Binding AudioSettingDetailsNavigationItemViewModel}"/>
        <settingsView:SettingDetailsNavigationItem 
            DataContext="{Binding AudioProcessingSettingDetailNavigationItemViewModel}"/>
        <settingsView:SettingDetailsNavigationItem
            DataContext="{Binding TextDisplaySettingDetailsNavigationItemViewModel}"/>
    </StackPanel>
</reactive:ReactiveUserControl>