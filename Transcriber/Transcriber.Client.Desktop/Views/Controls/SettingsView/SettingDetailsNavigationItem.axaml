<reactive:ReactiveUserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:reactive="http://reactiveui.net"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Transcriber.Client.Desktop.ViewModels.Controls.SettingsView"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    mc:Ignorable="d" 
    x:Class="Transcriber.Client.Desktop.Views.Controls.SettingsView.SettingDetailsNavigationItem"
    x:DataType="vm:SettingDetailsNavigationItemViewModel"
    x:TypeArguments="vm:SettingDetailsNavigationItemViewModel">
    
    <Button Command="{Binding NavigateCommand}"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Cursor="Hand">
        
        <Button.Template>
            <ControlTemplate>
                <Border Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="16">
                    
                    <Grid HorizontalAlignment="Stretch" ColumnDefinitions="Auto,*,Auto">

                        <material:MaterialIcon 
                            Grid.Column="0"
                            Kind="{Binding Icon}"
                            Width="24"
                            Height="24"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ThemeForegroundBrush}"/>
                        
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="0">
                            <TextBlock 
                                Text="{Binding Text}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource ThemeForegroundBrush}"/>
                            
                            <TextBlock 
                                Text="{Binding Description}"
                                FontSize="12"
                                Opacity="0.7"
                                Foreground="{DynamicResource ThemeForegroundBrush}"/>
                        </StackPanel>
                        
                        <Border Grid.Column="2"
                                VerticalAlignment="Center"
                                Classes="SettingDetailsNavigationArrow"
                                Margin="8, 0, 0, 0"
                                CornerRadius="16">
                            <material:MaterialIcon
                                Kind="ChevronRight"
                                Width="24"
                                Height="24"
                                Foreground="{DynamicResource ThemeForegroundBrush}"/>
                        </Border>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Button.Template>
        
        <Button.Styles>
            <Style Selector="Button">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="Button:pointerover Border.SettingDetailsNavigationArrow">
                <Setter Property="Background" Value="#cccccc"/>
            </Style>
            <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="{DynamicResource ThemeControlMidBrush}"/>
            </Style>
            <Style Selector="Button:pressed">
                <Setter Property="Background" Value="{DynamicResource ThemeControlHighBrush}"/>
            </Style>
        </Button.Styles>
    </Button>
</reactive:ReactiveUserControl>
