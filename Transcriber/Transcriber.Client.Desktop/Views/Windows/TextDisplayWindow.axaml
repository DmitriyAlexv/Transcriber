<reactive:ReactiveWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:reactive="http://reactiveui.net"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Transcriber.Client.Desktop.ViewModels.Windows"
        mc:Ignorable="d"
        x:Class="Transcriber.Client.Desktop.Views.Windows.TextDisplayWindow"
        x:TypeArguments="vm:TextDisplayViewModel"
        x:DataType="vm:TextDisplayViewModel"
        Title="Text Display"
        Width="{Binding Settings.WindowWidth}"
        Height="{Binding Settings.WindowHeight}"
        WindowStartupLocation="Manual"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        IsVisible="{Binding IsVisible}">
    <Border Background="Transparent" 
            CornerRadius="10"
            Opacity="{Binding Settings.WindowOpacity}"
            BorderThickness="1"
            BorderBrush="#FF404040"
            Margin="1">
        <TextBlock Text="{Binding DisplayText}"
                   FontSize="{Binding Settings.FontSize}"
                   Opacity="{Binding Settings.TextOpacity}"
                   Foreground="White"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="20"/>
    </Border>
</reactive:ReactiveWindow>
